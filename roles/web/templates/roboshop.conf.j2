proxy_http_version 1.1;
location /images/ {
  expires 5s;
  root   /usr/share/nginx/html;
  try_files $uri /images/placeholder.jpg;
}

#with lb we are call from app alb which has accept so port numbers are not required
location /api/catalogue/ { proxy_pass http://{{CATALOGUE_HOST}}/; }
location /api/user/ { proxy_pass http://{{USER_HOST}}/; }
location /api/cart/ { proxy_pass http://{{CART_HOST}}/; }
location /api/shipping/ { proxy_pass http://{{SHIPPING_HOST}}/; }
location /api/payment/ { proxy_pass http://{{PAYMENT_HOST}}/; }

location /health {
  stub_status on;
  access_log off;
}